# Copy to .env and replace values for your environment.
# -------------------------------
# Secrets / sensitive values (top)
# -------------------------------
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change_me

KC_DB=postgres
KC_DB_NAME=keycloak
KC_DB_URL=jdbc:postgresql://postgres:5432/keycloak


# Master realm admin (for kcadm login to master)
KC_MASTER_ADMIN_USER=change_master_admin_user
KC_MASTER_ADMIN_PASSWORD=change_master_admin_password

# Target realm
KC_NEW_REALM_NAME=org-new-delhi

# New realm admin
KC_NEW_REALM_ADMIN_USER=change_realm_admin_user
KC_NEW_REALM_ADMIN_PASSWORD=change_realm_admin_password
KC_NEW_REALM_ADMIN_EMAIL=change_realm_admin_email
KC_NEW_REALM_ADMIN_FIRST_NAME=change_realm_admin_first_name
KC_NEW_REALM_ADMIN_LAST_NAME=change_realm_admin_last_name


KC_HOSTNAME=https://login.example.com
KC_HOSTNAME_ADMIN=https://admin.example.com
KC_PROXY_TRUSTED_ADDRESSES=10.0.0.10/32

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_SSL=false

# -------------------------------
# Static runtime/build config
# -------------------------------

# Build-time options (requires image rebuild)
KC_FEATURES=admin-fine-grained-authz:v2,passkeys:v1,recovery-codes:v1,impersonation:v1
KC_BUILD_OPTS=
# Runtime options
JAVA_OPTS_APPEND="-Djava.net.preferIPv4Stack=true -Xms1g -Xmx1g -XX:ActiveProcessorCount=2"
KC_STARTUP_EXTRA_OPTS=


# Hostname / proxy hardening
KC_HOSTNAME_STRICT=true
KC_PROXY_HEADERS=xforwarded
KC_PROXY_PROTOCOL_ENABLED=false

# HTTP listener
KC_HTTP_ENABLED=true
# Container-safe default; docker compose maps this to 0.0.0.0 at runtime.
KC_HTTP_HOST=127.0.0.1
KC_HTTP_PORT=8080

# Database connection/runtime tuning
KC_DB_POOL_MIN_SIZE=10
KC_DB_POOL_INITIAL_SIZE=10
KC_DB_POOL_MAX_SIZE=50
KC_DB_POOL_MAX_LIFETIME=30m

# Observability
KC_HTTP_MANAGEMENT_PORT=9000
# Container-safe default; docker compose maps this to 0.0.0.0 at runtime.
KC_HTTP_MANAGEMENT_HOST=127.0.0.1
KC_HTTP_MANAGEMENT_RELATIVE_PATH=/management
KC_HTTP_MANAGEMENT_HEALTH_ENABLED=true
KC_HTTP_MANAGEMENT_SCHEME=http
KC_HTTP_ACCESS_LOG_ENABLED=false

KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true
KC_HTTP_RELATIVE_PATH=/

# Logging
KC_LOG=file
KC_LOG_FILE=/var/log/keycloak/keycloak.log
KC_LOG_LEVEL=info


# Custom OTP test API hardening
KC_OTP_TEST_API_ENABLED=false
KC_OTP_TEST_API_ALLOWED_HOSTS=

# Step 8 audit retention (default: 270 days)
EVENTS_EXPIRATION_SECONDS=23328000

# Host path bind-mounted to /var/log/keycloak in container
KC_HOST_LOG_DIR=./logs/keycloak
# Failure-only event stream path used by failure-logs-file listener
KC_FAILURE_LOG_FILE=/var/log/keycloak/failure-auth.log
# Optional ownership alignment for host bind mount (set if needed)
# KEYCLOAK_LOG_UID=1000
# KEYCLOAK_LOG_GID=1000

# Step 9 archive export settings
AUDIT_EXPORT_OUTPUT_DIR=/workspace/exports/audit
AUDIT_EXPORT_STATE_FILE=/workspace/exports/audit/state/watermark.json
# AUDIT_EXPORT_START_DATE=2026-03-01
# AUDIT_EXPORT_END_DATE=2026-03-05
AUDIT_EXPORT_BATCH_SIZE=500
