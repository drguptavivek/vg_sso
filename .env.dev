# Development-only overrides applied by docker-compose.override.yml.
# Keep this file minimal; base settings come from .env.

# Simple local bootstrap admin for dev

# Dev logging / debug behavior
KC_LOG_FILE=/tmp/keycloak-dev.log
KC_HTTP_ACCESS_LOG_ENABLED=true

# Enable OTP test helper endpoints in dev
# Enable OTP test helper endpoints in dev
KC_OTP_TEST_API_ENABLED=true

KEYCLOAK_ENV=development
