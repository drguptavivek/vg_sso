<?xml version="1.0" encoding="UTF-8"?>
<!--
  Empty beans.xml — marks this JAR as a CDI bean archive (discovery-mode=all).
  Required for Keycloak Quarkus to include this JAR in the Arc CDI container
  and for RESTEasy to discover @Provider-annotated classes from the Jandex index.
-->
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       version="4.0"
       bean-discovery-mode="all">
</beans>
